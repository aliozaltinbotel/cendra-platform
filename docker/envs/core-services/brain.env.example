# CENDRA-HOOK(T8): Cendra brain kernel environment (FORK_LEDGER.md).
# Copy to brain.env to activate. Everything defaults to OFF / unset —
# with this file absent or empty the deployment behaves exactly like
# upstream Dify.

# ── Gate chain (T1/T3) ───────────────────────────────────────────────
# off (default) | observe (evaluate + log, never block) | enforce
BRAIN_GATES_MODE=off
# Optional comma-separated tenant allowlist for observe/enforce —
# the P2 phase gate runs exactly one workspace in observe.
BRAIN_GATES_TENANTS=

# ── Embedding pod (Batch 3 decision: no model weights in api image) ──
# OpenAI-compatible /embeddings server (TEI, infinity, …)
BRAIN_EMBEDDING_ENDPOINT=
BRAIN_EMBEDDING_API_KEY=
# Model + dim must match the Qdrant collections (see
# core/brain/memory/embedding_config.py re-embedding warning)
BRAIN_EMBEDDING_MODEL=
BRAIN_EMBEDDING_DIM=

# ── Hybrid retrieval (BM25 sparse + RRF) ─────────────────────────────
# Requires Qdrant collections created with named sparse vectors; the
# brain memory code creates its own collections accordingly when the
# flag is on. fastembed runs in-process (small ONNX BM25 model).
BRAIN_HYBRID_RETRIEVAL_ENABLED=false

# ── Per-scenario feature whitelists (Sprint H mechanism) ─────────────
BRAIN_SCENARIO_FEATURES_ENABLED=false

# ── Bi-temporal Property Knowledge (CEN-15 / CEN-27) ─────────────────
# Brain kernel External-Knowledge endpoint (the `/retrieval` base URL the
# kernel serves for as-of Property Knowledge). When set, kernel-bound
# retrieve requests carry the run's decision-time `as_of` (ruling §E1);
# unset, the threading is inert and behavior is upstream-identical.
BRAIN_KERNEL_KNOWLEDGE_ENDPOINT=
