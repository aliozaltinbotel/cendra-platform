# ══════════════════════════════════════════════════════════════════════
# Brain Engine — Production Environment Variables
# Copy to .env and fill in values from Cendra team
# ══════════════════════════════════════════════════════════════════════

# ── 1. Azure OpenAI (LLM) ───────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://cendra-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
AZURE_OPENAI_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Optional — set when an Azure Whisper deployment is provisioned.
# Empty = voice transcription endpoints respond 503.
AZURE_OPENAI_WHISPER_DEPLOYMENT=

# ── 2. Redis ─────────────────────────────────────────────────────────
REDIS_URL=rediss://cendra-redis.redis.cache.windows.net:6380?password=REPLACE

# ── 3. Qdrant (Vector Database) ─────────────────────────────────────
QDRANT_URL=https://cendra.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=brain_engine_knowledge

# ── 4. PostgreSQL (Checkpointer) ────────────────────────────────────
DATABASE_URL=postgresql://brain_engine:REPLACE@cendra-pg.postgres.database.azure.com:5432/brain_engine?sslmode=require

# ── 4b. Botel/Bookly.Pms MySQL (Azure, read-only integration) ──────
# Формат .NET connection string, полученный от команды botelllm:
#   Server=<host>;database=<db>;user id=<user>;password=<pwd>;SslMode=Required
# Для Python разложено на отдельные поля и готовый aiomysql URL.
BOTEL_MYSQL_HOST=botelmysql.mysql.database.azure.com
BOTEL_MYSQL_PORT=3306
BOTEL_MYSQL_DB=botelpms-dev
BOTEL_MYSQL_USER=
BOTEL_MYSQL_PASSWORD=
BOTEL_MYSQL_SSL=required
BOTEL_MYSQL_URL=

# ── 5. ElevenLabs (Voice Calls) ─────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_AGENT_ID=

# ── 6. Server Configuration ─────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
WORKERS=4
ALLOWED_ORIGINS=["https://dev.botel.ai","https://app.cendra.ai"]
MAX_RETRIES=3
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── 7. Brain Engine API ─────────────────────────────────────────────
API_BASE_URL=https://brain.cendra.ai
API_AUTH_TOKEN=

# ── 8. Cendra Integration ───────────────────────────────────────────
CENDRA_PMS_API_URL=https://pms.botel.ai
CENDRA_PMS_API_KEY=
CENDRA_WEBHOOK_SECRET=
