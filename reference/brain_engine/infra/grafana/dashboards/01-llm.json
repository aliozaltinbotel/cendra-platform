        }
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []}
    },
    {
      "title": "LLM call latency p95 by model (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(brain_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "Tokens / minute by model",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "id": 3,
      "targets": [
        {
          "expr": "sum by (model) (rate(brain_llm_tokens_input_total[1m])) * 60",
