      "title": "LLM cost (USD/hour) by model",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum by (model) (rate(brain_llm_cost_usd_total[5m])) * 3600",
