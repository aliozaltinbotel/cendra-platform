                  "console.log('status:', body.status, '| started_at:', body.started_at);",
                  "if (body.status === 'completed') {",
                  "  console.log('report:', JSON.stringify(body.report, null, 2));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
